# ============================================================
# Pungctual environment variables
#
# Copy to .env.local for development. In production (Vercel),
# set these under Project Settings → Environment Variables.
#
# Every variable the codebase reads is listed here. Several have
# hardcoded production fallbacks in code — DO NOT rely on them:
# an environment that forgets NEXT_PUBLIC_APP_URL silently builds
# invite/Stripe/calendar links pointing at PRODUCTION.
# ============================================================

# --- Supabase (required) ---
# Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key. Server-only, bypasses RLS — never expose client-side.
# Used by server actions: billing, invites, discovery, account deletion.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Canonical app origin (required) ---
# Builds invite links, Stripe success/cancel URLs, calendar (.ics) links,
# and trial-reminder emails. Code falls back to https://pungctual.com when
# unset, which masks misconfiguration — set it explicitly per environment.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stripe (required for billing) ---
# Live keys in production; test keys (sk_test_/price_ test mode) locally.
STRIPE_SECRET_KEY=sk_test_xxx
# Signing secret for the webhook endpoint (Stripe dashboard → Webhooks).
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs for the two Pro plans.
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_ANNUAL=price_xxx

# --- Resend (required for email: club/event invites, reminders, .ics) ---
RESEND_API_KEY=re_xxx
# Verified sender identity. Bare address or full "Name <address>" form —
# both accepted; lib/resend-from.ts normalizes. (Documenting the full form
# while call sites wrapped it again used to nest brackets → Resend 422.)
RESEND_FROM_EMAIL=hello@pungctual.com

# --- Cron auth (required in production) ---
# Bearer token Vercel crons send to the reminder/billing routes. The
# reminders cron fails closed without it, but billing-expire does NOT
# (open finding M-1 in CODE_AUDIT_2026-06-10) — always set it in prod.
CRON_SECRET=generate-a-long-random-string

# --- Web Push / VAPID (required for push notifications) ---
# Generate a key pair once:  npx web-push generate-vapid-keys
# The PUBLIC key is read in two places — server (VAPID_PUBLIC_KEY) and
# client bundle (NEXT_PUBLIC_VAPID_PUBLIC_KEY). Set BOTH to the same value.
VAPID_SUBJECT=mailto:hello@pungctual.com
VAPID_PUBLIC_KEY=your-vapid-public-key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# --- Auto-injected (do not set manually) ---
# NEXT_PUBLIC_APP_VERSION is stamped from package.json by next.config.
